# ─────────────────────────────────────────────
# LRC Guide – Required Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to GitHub.

# Google Gemini (PaLM) API Key
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Google Service Account (for Sheets access)
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Download the JSON key and reference it in n8n credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account-key.json

# Google Sheet ID for the Knowledge Base
# Found in the Sheets URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here
